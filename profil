    <!-- Script Javascript pour gérer les onglets -->
    <script>
        lucide.createIcons();

        function switchTab(tabId) {
            // Cacher tous les contenus
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            // Afficher le contenu ciblé
            document.getElementById('tab-' + tabId).classList.remove('hidden');

            // Réinitialiser les styles de tous les boutons
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('text-[#A78BFA]', 'border-[#A78BFA]');
                el.classList.add('text-[#A1A1AA]', 'border-transparent');
            });
            // Activer le style du bouton cliqué
            let activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.classList.remove('text-[#A1A1AA]', 'border-transparent');
            activeBtn.classList.add('text-[#A78BFA]', 'border-[#A78BFA]');
        }
    </script>
