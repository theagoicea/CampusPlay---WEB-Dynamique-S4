<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Melody - Authentification</title>
    
    <!-- Importation de Tailwind CSS pour le style -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Importation de la librairie d'icônes Lucide -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-[#0B0B0F] text-[#F5F5F7] min-h-screen font-sans">

    <div class="flex min-h-screen">
        <!-- Barre latérale (Sidebar) -->
        <aside class="w-64 shrink-0 bg-[#18181B] border-r border-[#27272A] flex flex-col sticky top-0 h-screen overflow-y-auto">
            <div class="px-6 py-8 border-b border-[#27272A]">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 bg-[#A78BFA]/10 rounded-xl border border-[#A78BFA]/30 flex items-center justify-center text-lg">🎵</div>
                    <h1 class="text-sm font-bold text-[#F5F5F7] leading-tight">Campus Melody</h1>
                </div>
            </div>
            
            <nav class="flex-1 px-3 py-4">
                <p class="text-[10px] font-semibold text-[#A1A1AA] uppercase tracking-widest px-3 mb-3">Pages</p>
                <div class="space-y-1">
                    <!-- Bouton Actif (Authentification) -->
                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left bg-[#A78BFA] text-[#0B0B0F] font-bold">
                        <i data-lucide="user" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Authentification</span>
                    </button>
                    
                    <!-- Boutons Inactifs -->
                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="home" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Accueil</span>
                    </button>

                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="calendar" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Catalogue</span>
                    </button>

                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="music" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Détail Événement</span>
                    </button>

                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="settings" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Réservation</span>
                    </button>

                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="user" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Profil</span>
                    </button>

                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="bell" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Notifications</span>
                    </button>

                    <button class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all cursor-pointer text-left text-[#A1A1AA] hover:text-[#F5F5F7] hover:bg-[#27272A]">
                        <i data-lucide="layout-grid" class="w-4 h-4 shrink-0"></i>
                        <span class="text-sm font-medium">Tableau de bord admin</span>
                    </button>
                </div>
            </nav>
        </aside>

        <!-- Contenu Principal -->
        <main class="flex-1 overflow-y-auto">
            <div class="px-8 py-10">

                <!-- Composant Authentification -->
                <div class="bg-[#18181B] rounded-3xl p-8 text-[#F5F5F7] border border-[#27272A]">
                    <div class="mb-6">
                        <h3 class="text-2xl font-semibold mb-2">Authentification</h3>
                        <p class="text-[#A1A1AA]">Page de connexion</p>
                    </div>
                    <div class="bg-[#0B0B0F] rounded-2xl p-12 border-2 border-dashed border-[#A78BFA]/20 flex items-center justify-center">
                        <div class="w-full max-w-md bg-[#18181B] border border-[#27272A] rounded-2xl p-8 shadow-xl flex flex-col items-center">
                            
                            <div class="text-center mb-8">
                                <div class="w-16 h-16 bg-[#A78BFA]/10 rounded-2xl mx-auto mb-3 border border-[#A78BFA]/30 flex items-center justify-center text-[#A78BFA] font-bold text-2xl">🎵</div>
                                <h4 class="text-xl font-bold tracking-tight text-[#F5F5F7]">Campus Melody</h4>
                            </div>
                            
                            <div class="w-full space-y-4">
                                <input type="text" placeholder="Email" class="w-full h-12 bg-[#0B0B0F] rounded-xl border border-[#27272A] px-4 text-sm text-[#F5F5F7] placeholder-[#A1A1AA] focus:outline-none focus:border-[#A78BFA]/50" />
                                <input type="password" placeholder="Mot de passe" class="w-full h-12 bg-[#0B0B0F] rounded-xl border border-[#27272A] px-4 text-sm text-[#F5F5F7] placeholder-[#A1A1AA] focus:outline-none focus:border-[#A78BFA]/50" />
                                <button class="w-full h-12 bg-[#A78BFA] text-[#0B0B0F] rounded-xl font-semibold flex items-center justify-center text-sm cursor-pointer hover:bg-[#A78BFA]/90 transition">
                                    Connexion
                                </button>
                                <div class="text-center pt-2">
                                    <p class="text-xs text-[#A1A1AA]">
                                        Pas de compte ? 
                                        <span class="text-[#A78BFA] font-medium hover:underline cursor-pointer">Inscris-toi ici</span>
                                    </p>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
                <!-- Fin Composant Authentification -->

            </div>
        </main>
    </div>

    <!-- Script d'initialisation pour afficher les icônes Lucide -->
    <script>
      lucide.createIcons();
    </script>
</body>
</html>
