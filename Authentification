<?php
session_start();

// Connexion à la base de données (MAMP utilise souvent root/root par défaut)
$host = 'localhost';
$dbname = 'campusmelody';
$username = 'root';
$password = 'root'; 

try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname;charset=utf8", $username, $password);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
} catch (PDOException $e) {
    die("Erreur de connexion : " . $e->getMessage());
}

$email_error = '';
$password_error = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $email = $_POST['email'];
    $mdp = $_POST['mot_de_passe'];

    // Vérification de l'email
    $stmt = $pdo->prepare("SELECT * FROM utilisateur WHERE email = :email");
    $stmt->execute(['email' => $email]);
    $user = $stmt->fetch();

    if (!$user) {
        $email_error = "Compte non-existant";
    } else {
        // Vérification du mot de passe (gère les mots de passe en texte clair ou hachés)
        if ($mdp !== $user['mot_de_passe'] && !password_verify($mdp, $user['mot_de_passe'])) {
            $password_error = "Mot de passe incorecte";
        } else {
            // Connexion réussie : on stocke les infos en session et on redirige
            $_SESSION['user_id'] = $user['id_utilisateur'];
            $_SESSION['role'] = $user['role'];
            $_SESSION['prenom'] = $user['prenom'];
            
            header("Location: profil.php"); // Redirige vers le profil après connexion
            exit();
        }
    }
}
